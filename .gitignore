# ============================================================
# Python
# ============================================================
__pycache__/
*.pyc
*.pyo
*$py.class
# NOTE: do NOT ignore *.pyd here (Windows compiled extension modules, e.g.
# numpy/pydantic_core/cryptography's binary backends under lib/) -- the old
# `*.py[cod]` pattern matched .pyd too, silently excluding every vendored
# binary dependency from git and therefore from every release zip. This
# was the real cause of the MCP server never starting on release installs.
*.so
*.egg-info/
dist/
build/

# ============================================================
# MorfyAI runtime data (private, user-specific)
# ============================================================
cache/
trainData/
*.hperf

# Config files contain API keys & user preferences — never push
config/houdini_ai.ini

# Local release build output (tools/release/build_zip.py)
/release/
config/plugins.json
config/user_rules.json

# ============================================================
# Original upstream backup (Kazama's Houdini Agent v1.5.5)
# Not part of MorfyAI distribution — kept locally for reference only
# ============================================================
houdini_agent_backup/

# ============================================================
# IDE / editor
# ============================================================
.idea/
.vscode/
.cursor/
.claude/
*.swp
*.swo
*~

# ============================================================
# Temp / backup files
# ============================================================
*_backup.py
*_new.py
*.bak
*.tmp
*.log

# ============================================================
# Legacy
# ============================================================
HOUDINI_HIP_MANAGER/

# ============================================================
# OS junk
# ============================================================
Thumbs.db
.DS_Store
desktop.ini

# sim render flipbook scratch dirs
_*/
